{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",      "use": "@vercel/node" },
    { "src": "api/video.js",     "use": "@vercel/node" },
    { "src": "api/upscale.js",   "use": "@vercel/node" },
    { "src": "api/credits.js",   "use": "@vercel/node" },
    { "src": "api/director.js",  "use": "@vercel/node" },
    { "src": "api/pexels.js",    "use": "@vercel/node" },
    { "src": "api/wavespeed.js", "use": "@vercel/node" },
    { "src": "api/qa-agent.js",  "use": "@vercel/node" },
    { "src": "api/checkout.js",  "use": "@vercel/node" },
    { "src": "api/webhook.js",   "use": "@vercel/node" },
    { "src": "*.html",           "use": "@vercel/static" },
    { "src": "public/**",        "use": "@vercel/static" },
    { "src": "media/**",         "use": "@vercel/static" },
    { "src": "js/**",            "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/qa-agent",  "dest": "/api/qa-agent.js"  },
    { "src": "/api/wavespeed", "dest": "/api/wavespeed.js" },
    { "src": "/api/chat",      "dest": "/api/chat.js"      },
    { "src": "/api/video",     "dest": "/api/video.js"     },
    { "src": "/api/upscale",   "dest": "/api/upscale.js"   },
    { "src": "/api/credits",   "dest": "/api/credits.js"   },
    { "src": "/api/director",  "dest": "/api/director.js"  },
    { "src": "/api/pexels",    "dest": "/api/pexels.js"    },
    { "src": "/api/checkout",  "dest": "/api/checkout.js"  },
    { "src": "/api/webhook",   "dest": "/api/webhook.js"   },
    { "src": "/hero1.mp4",     "dest": "/media/hero1.mp4"  },
    { "src": "/hero2.mp4",     "dest": "/media/hero2.mp4"  },
    { "src": "/hero3.mp4",     "dest": "/media/hero3.mp4"  },
    { "src": "/",              "dest": "/index.html"        },
    { "src": "/(.*).html",     "dest": "/$1.html"          },
    { "src": "/(.*)",          "dest": "/$1"               }
  ]
}
