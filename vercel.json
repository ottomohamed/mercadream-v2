{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",  "use": "@vercel/node" },
    { "src": "api/video.js", "use": "@vercel/node" },
    { "src": "*.html",       "use": "@vercel/static" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",    "dest": "/api/chat.js"  },
    { "src": "/api/video",   "dest": "/api/video.js" },
    { "src": "/",            "dest": "/index.html"   },
    { "src": "/(.*)\\.html", "dest": "/$1.html"      },
    { "src": "/(.*)",        "dest": "/$1"           }
  ]
}
